{
  "name": "@carelearn/api",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node -e \"require('./src/models/index.js').createTables().then(() => process.exit(0))\"",
    "seed": "node src/seed.js",
    "test": "node --test src/lib/certificate-pdf.test.js src/lib/lesson-content.test.js src/lib/rich-content.test.js src/services/queue/queueManager.test.js src/middleware/permissions.test.js",
    "smoke": "node src/scripts/smoke-api.js",
    "verify:health": "node src/scripts/verify-health.js",
    "verify:workflow": "node src/scripts/workflow-checks.js",
    "media:orphans": "node src/scripts/detect-orphan-media.js",
    "media:jobs": "node src/scripts/media-jobs-runner.js",
    "diagnostics": "node src/scripts/diagnostics-report.js",
    "db:integrity": "node src/scripts/db-integrity-check.js",
    "db:index-health": "node src/scripts/index-health-check.js",
    "tenant:verify": "node src/scripts/tenant-isolation-check.js",
    "audit:retention": "node src/scripts/audit-retention.js",
    "backup:json": "node src/scripts/export-backup-json.js",
    "migrate:record": "node src/scripts/record-migration-version.js",
    "db:schema-drift": "node src/scripts/schema-drift-check.js",
    "backup:verify": "node src/scripts/restore-verify.js",
    "governance:run": "node src/scripts/governance-policy-runner.js"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.100",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "nodemon": "^3.1.14"
  }
}
