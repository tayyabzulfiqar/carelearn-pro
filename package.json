{
  "name": "carelearn-pro",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "fire-safety:import": "node apps/api/src/scripts/import-fire-safety-course.js",
    "fire-safety:validate": "node apps/api/src/scripts/validate-fire-safety-system.js",
    "fire-safety:test": "node --test apps/api/src/lib/fire-safety-course.test.js apps/api/src/lib/quiz-data.test.js apps/api/src/lib/certificate-template.test.js apps/web/src/lib/coursePlayerState.test.js apps/web/src/lib/quizSession.test.js apps/web/src/lib/lesson-sections.test.js"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
